# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Flask secret key — generate a random string, e.g.:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Anthropic API key — from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth credentials — from Google Cloud Console
# Required for Search Console, Analytics, and Google Docs export
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Set this to your actual domain in production
# Must match the redirect URI configured in Google Cloud Console
GOOGLE_REDIRECT_URI=https://contenttracker.yourdomain.com/oauth/callback

# Optional: set to 'true' for local development only
FLASK_DEBUG=false
